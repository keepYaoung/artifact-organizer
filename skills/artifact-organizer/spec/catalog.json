{
  "version": "artifact-organizer/v1",
  "envelope": {
    "a2ui_version": "0.9",
    "required": ["a2ui_version", "catalog", "parts"],
    "root_component": "artifact-organizer/Page"
  },
  "components": {
    "artifact-organizer/Page": {
      "description": "Root container. Exactly one Page per envelope.",
      "children": "required",
      "props": {
        "title": { "type": "string", "required": true },
        "subtitle": { "type": "string" },
        "toc": { "type": "boolean", "default": false },
        "chromeless": { "type": "boolean", "default": false, "description": "When true, suppresses the default page header. Use for site-mode rendering where SiteHeader/HeroCarousel provide chrome." },
        "backHref": { "type": "string", "description": "When set, renders a sticky back-navigation bar at the top of the page linking back to the given URL. Use for multi-HTML linking (e.g. '← index.html')." },
        "backLabel": { "type": "string", "description": "Label for the back navigation link. Defaults to '← Back'." }
      }
    },
    "artifact-organizer/Section": {
      "description": "First-class section. Auto TOC anchor.",
      "children": "allowed",
      "props": {
        "id": { "type": "string", "required": true, "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "title": { "type": "string", "required": true },
        "lead": { "type": "string", "description": "Markdown lead paragraph" }
      }
    },
    "artifact-organizer/Heading": {
      "description": "In-section heading (h2-h4).",
      "children": "forbidden",
      "props": {
        "level": { "type": "number", "enum": [2, 3, 4], "required": true },
        "text": { "type": "string", "required": true },
        "anchor": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" }
      }
    },
    "artifact-organizer/Prose": {
      "description": "Markdown paragraph block (inline formatting + lists).",
      "children": "forbidden",
      "props": {
        "markdown": { "type": "string", "required": true }
      }
    },
    "artifact-organizer/Image": {
      "description": "Inline image. Accepts https:// URLs (passed through) or local paths (base64-inlined at render time to keep the HTML self-contained).",
      "children": "forbidden",
      "props": {
        "src": { "type": "string", "required": true },
        "alt": { "type": "string", "required": true },
        "caption": { "type": "string" },
        "width": { "type": "number" },
        "height": { "type": "number" }
      }
    },
    "artifact-organizer/Callout": {
      "description": "Boxed highlight.",
      "children": "forbidden",
      "props": {
        "severity": { "type": "string", "enum": ["info", "note", "warn", "success", "danger"], "required": true },
        "title": { "type": "string" },
        "body": { "type": "string", "required": true }
      }
    },
    "artifact-organizer/KPICard": {
      "description": "Metric card with optional delta.",
      "children": "forbidden",
      "props": {
        "label": { "type": "string", "required": true },
        "value": { "type": "string", "required": true },
        "delta": {
          "type": "object",
          "props": {
            "value": { "type": "string", "required": true },
            "direction": { "type": "string", "enum": ["up", "down", "flat"], "required": true }
          }
        },
        "hint": { "type": "string" }
      }
    },
    "artifact-organizer/CodeBlock": {
      "description": "Single code snippet.",
      "children": "forbidden",
      "props": {
        "lang": { "type": "string", "required": true },
        "code": { "type": "string", "required": true },
        "filename": { "type": "string" },
        "highlight": { "type": "array", "items": { "type": "number" } }
      }
    },
    "artifact-organizer/CodeDiff": {
      "description": "Before/after unified diff.",
      "children": "forbidden",
      "props": {
        "filename": { "type": "string", "required": true },
        "lang": { "type": "string", "required": true },
        "hunks": {
          "type": "array",
          "required": true,
          "items": {
            "type": "object",
            "props": {
              "before": { "type": "string", "required": true },
              "after": { "type": "string", "required": true },
              "atLine": { "type": "number" }
            }
          }
        }
      }
    },
    "artifact-organizer/Mermaid": {
      "description": "Mermaid.js diagram wrapper with zoom/pan.",
      "children": "forbidden",
      "props": {
        "kind": { "type": "string", "enum": ["flowchart", "sequence", "er", "state", "mindmap", "class"], "required": true },
        "source": { "type": "string", "required": true },
        "direction": { "type": "string", "enum": ["TD", "LR"] }
      }
    },
    "artifact-organizer/Sequence": {
      "description": "Native SVG sequence diagram, Artifact Organizer-styled. Prefer over Mermaid 'sequence' when you want consistent design and no external CDN.",
      "children": "forbidden",
      "props": {
        "participants": {
          "type": "array",
          "required": true,
          "items": {
            "type": "object",
            "props": {
              "id": { "type": "string", "required": true },
              "title": { "type": "string", "required": true },
              "subtitle": { "type": "string" }
            }
          }
        },
        "messages": {
          "type": "array",
          "required": true,
          "items": {
            "type": "object",
            "props": {
              "from": { "type": "string" },
              "to": { "type": "string" },
              "text": { "type": "string", "required": true },
              "kind": { "type": "string", "enum": ["sync", "async", "return", "self", "note"] },
              "over": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    },
    "artifact-organizer/ArchitectureGrid": {
      "description": "Card-based architecture with SVG connectors.",
      "children": "forbidden",
      "props": {
        "nodes": {
          "type": "array",
          "required": true,
          "items": {
            "type": "object",
            "props": {
              "id": { "type": "string", "required": true },
              "title": { "type": "string", "required": true },
              "description": { "type": "string" },
              "icon": { "type": "string" },
              "tag": { "type": "string" }
            }
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "props": {
              "from": { "type": "string", "required": true },
              "to": { "type": "string", "required": true },
              "label": { "type": "string" },
              "style": { "type": "string", "enum": ["data", "control", "dep"] }
            }
          }
        },
        "layout": { "type": "string", "enum": ["grid", "columns", "layers"], "required": true },
        "groups": {
          "type": "array",
          "items": {
            "type": "object",
            "props": {
              "id": { "type": "string", "required": true },
              "title": { "type": "string", "required": true },
              "nodeIds": { "type": "array", "items": { "type": "string" }, "required": true }
            }
          }
        }
      }
    },
    "artifact-organizer/FlowChart": {
      "description": "Native SVG directed graph. Ranked layout (TD or LR) — caller provides `ranks` (array of arrays of node ids) so no layout solver is needed. Prefer over Mermaid flowchart for simple pipelines with consistent design.",
      "children": "forbidden",
      "props": {
        "layout": { "type": "string", "enum": ["TD", "LR"], "required": true },
        "nodes": {
          "type": "array",
          "required": true,
          "items": {
            "type": "object",
            "props": {
              "id": { "type": "string", "required": true },
              "label": { "type": "string", "required": true },
              "shape": { "type": "string", "enum": ["box", "pill", "diamond"] },
              "tag": { "type": "string" }
            }
          }
        },
        "edges": {
          "type": "array",
          "required": true,
          "items": {
            "type": "object",
            "props": {
              "from": { "type": "string", "required": true },
              "to": { "type": "string", "required": true },
              "label": { "type": "string" }
            }
          }
        },
        "ranks": {
          "type": "array",
          "required": true,
          "items": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "artifact-organizer/Quadrant": {
      "description": "2x2 prioritization matrix with plotted points.",
      "children": "forbidden",
      "props": {
        "xLabel": { "type": "string", "required": true },
        "yLabel": { "type": "string", "required": true },
        "quadrants": {
          "type": "array",
          "required": true,
          "items": {
            "type": "object",
            "props": {
              "id": { "type": "string", "required": true },
              "title": { "type": "string", "required": true },
              "description": { "type": "string" }
            }
          }
        },
        "points": {
          "type": "array",
          "items": {
            "type": "object",
            "props": {
              "label": { "type": "string", "required": true },
              "x": { "type": "number", "required": true },
              "y": { "type": "number", "required": true },
              "tag": { "type": "string" },
              "tone": { "type": "string", "enum": ["accent", "muted", "success", "warn"] }
            }
          }
        }
      }
    },
    "artifact-organizer/Swimlane": {
      "description": "Lane-based process diagram laid out on a shared timeline.",
      "children": "forbidden",
      "props": {
        "lanes": {
          "type": "array",
          "required": true,
          "items": {
            "type": "object",
            "props": {
              "id": { "type": "string", "required": true },
              "title": { "type": "string", "required": true },
              "subtitle": { "type": "string" }
            }
          }
        },
        "steps": {
          "type": "array",
          "required": true,
          "items": {
            "type": "object",
            "props": {
              "id": { "type": "string", "required": true },
              "lane": { "type": "string", "required": true },
              "title": { "type": "string", "required": true },
              "description": { "type": "string" },
              "tag": { "type": "string" }
            }
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "props": {
              "from": { "type": "string", "required": true },
              "to": { "type": "string", "required": true },
              "label": { "type": "string" }
            }
          }
        }
      }
    },
    "artifact-organizer/DataTable": {
      "description": "Semantic HTML table.",
      "children": "forbidden",
      "props": {
        "columns": {
          "type": "array",
          "required": true,
          "items": {
            "type": "object",
            "props": {
              "key": { "type": "string", "required": true },
              "label": { "type": "string", "required": true },
              "align": { "type": "string", "enum": ["left", "center", "right"] },
              "wrap": { "type": "boolean" }
            }
          }
        },
        "rows": { "type": "array", "required": true, "items": { "type": "object" } },
        "caption": { "type": "string" },
        "footer": { "type": "object" },
        "density": { "type": "string", "enum": ["compact", "standard"] }
      }
    },
    "artifact-organizer/Chart": {
      "description": "Chart.js wrapper.",
      "children": "forbidden",
      "props": {
        "kind": { "type": "string", "enum": ["line", "bar", "pie", "area", "scatter"], "required": true },
        "data": {
          "type": "object",
          "required": true,
          "props": {
            "labels": { "type": "array", "items": { "type": "string" }, "required": true },
            "series": {
              "type": "array",
              "required": true,
              "items": {
                "type": "object",
                "props": {
                  "name": { "type": "string", "required": true },
                  "values": { "type": "array", "items": { "type": "number" }, "required": true }
                }
              }
            }
          }
        },
        "xLabel": { "type": "string" },
        "yLabel": { "type": "string" },
        "unit": { "type": "string" }
      }
    },
    "artifact-organizer/Comparison": {
      "description": "N-way comparison layout.",
      "children": "forbidden",
      "props": {
        "items": {
          "type": "array",
          "required": true,
          "items": {
            "type": "object",
            "props": {
              "title": { "type": "string", "required": true },
              "subtitle": { "type": "string" },
              "bullets": { "type": "array", "items": { "type": "string" }, "required": true },
              "verdict": {
                "type": "object",
                "props": {
                  "label": { "type": "string", "required": true },
                  "tone": { "type": "string", "required": true }
                }
              }
            }
          }
        },
        "mode": { "type": "string", "enum": ["vs", "grid"], "required": true }
      }
    },
    "artifact-organizer/StepList": {
      "description": "Ordered steps / checklist.",
      "children": "forbidden",
      "props": {
        "steps": {
          "type": "array",
          "required": true,
          "items": {
            "type": "object",
            "props": {
              "title": { "type": "string", "required": true },
              "body": { "type": "string", "required": true },
              "state": { "type": "string", "enum": ["done", "doing", "todo", "skipped"] }
            }
          }
        },
        "numbered": { "type": "boolean", "default": true }
      }
    },
    "artifact-organizer/SlideDeck": {
      "description": "Slide container.",
      "children": "required",
      "props": {
        "aspect": { "type": "string", "enum": ["16:9", "4:3"], "required": true },
        "transition": { "type": "string", "enum": ["none", "fade", "slide"] },
        "footer": { "type": "string" },
        "mode": { "type": "string", "enum": ["deck", "scroll-snap", "scroll-jack"], "description": "deck (default): keyboard/button nav, one slide at a time. scroll-snap: vertical scroll-snap with reveal-on-enter. scroll-jack: viewport-pinned slides with scroll-driven crossfade (Apple-style)." }
      }
    },
    "artifact-organizer/Slide": {
      "description": "Single slide.",
      "children": "forbidden",
      "props": {
        "layout": { "type": "string", "enum": ["title", "content", "two-col", "quote", "image", "section"], "required": true },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "bullets": { "type": "array", "items": { "type": "string" } },
        "image": { "type": "string" },
        "quote": { "type": "string" }
      }
    },
    "artifact-organizer/FileTree": {
      "description": "Directory/file structure visualization. Recursive nodes with optional highlights.",
      "children": "forbidden",
      "props": {
        "nodes": { "type": "array", "required": true, "description": "Recursive tree of { name, type: 'dir'|'file', path?, children?, highlight?: 'primary'|'secondary'|'muted' }" },
        "showIcons": { "type": "boolean", "default": true },
        "caption": { "type": "string" }
      }
    },
    "artifact-organizer/FileCard": {
      "description": "Per-file summary card — name, path, LOC, responsibility, exports, change state.",
      "children": "forbidden",
      "props": {
        "name":           { "type": "string", "required": true },
        "path":           { "type": "string" },
        "loc":            { "type": "number" },
        "responsibility": { "type": "string", "required": true },
        "exports":        { "type": "array", "description": "Array of { name, kind: 'function'|'class'|'const'|'type' }" },
        "state":          { "type": "string", "enum": ["modified","added","removed","stable"], "default": "stable" },
        "icon":           { "type": "string" }
      }
    },
    "artifact-organizer/AnnotatedCode": {
      "description": "Code block with numbered pins linking to side annotations.",
      "children": "forbidden",
      "props": {
        "lang":        { "type": "string", "required": true },
        "code":        { "type": "string", "required": true },
        "filename":    { "type": "string" },
        "annotations": { "type": "array", "required": true, "description": "Array of { line, pin, title, body }" },
        "pinStyle":    { "type": "string", "enum": ["numbered","lettered"], "default": "numbered" }
      }
    },
    "artifact-organizer/ERDDiagram": {
      "description": "Entity-relationship diagram — DB/type schemas with pk/fk/nullable markers and cardinality links.",
      "children": "forbidden",
      "props": {
        "entities":      { "type": "array", "required": true, "description": "Array of { id, name, fields: [{ name, type, key?: 'pk'|'fk', nullable?: boolean }] }" },
        "relationships": { "type": "array", "required": true, "description": "Array of { from, to, cardinality: '1-1'|'1-n'|'n-n', label? }" },
        "layout":        { "type": "string", "enum": ["grid","columns"], "default": "grid" }
      }
    },
    "artifact-organizer/ProjectTile": {
      "description": "Portfolio project tile — image + categories + title + optional client/year. Hover lift + image zoom on link variant. Use inside MosaicGrid for varied tile sizing, or in normal flow with intrinsic aspect.",
      "children": "forbidden",
      "props": {
        "title":      { "type": "string", "required": true },
        "image":      { "type": "string", "description": "Image URL (https or local path inlined at render). Empty = placeholder pattern." },
        "categories": { "type": "array", "items": { "type": "string" }, "description": "Small uppercase chips below the image." },
        "client":     { "type": "string", "description": "Client/brand name shown in metadata line." },
        "year":       { "type": "string", "description": "Project year, joined with client by ' · '." },
        "href":       { "type": "string", "description": "If set, the tile renders as <a> with hover lift." },
        "aspect":     { "type": "string", "enum": ["square","landscape","portrait","wide"], "default": "landscape", "description": "Intrinsic aspect ratio when not constrained by MosaicGrid row span." },
        "span":       { "type": "number", "description": "Inside MosaicGrid: column span 1..12 (default 4)." },
        "rowSpan":    { "type": "number", "description": "Inside MosaicGrid: row span 1..6 (default 1)." }
      }
    },
    "artifact-organizer/MosaicGrid": {
      "description": "Audi F1-inspired tile grid — CSS grid wrapper with auto-flow dense. Children (typically ProjectTile) declare span/rowSpan to create varied mosaic sizing. Collapses to 8-col @ 960px and 4-col @ 640px.",
      "children": "required",
      "props": {
        "columns":   { "type": "number", "default": 12, "description": "Number of grid columns (2..12)." },
        "gap":       { "type": "string", "default": "1rem", "description": "CSS length for grid gap." },
        "rowHeight": { "type": "string", "default": "minmax(200px, auto)", "description": "CSS value for grid-auto-rows." },
        "dense":     { "type": "boolean", "default": true, "description": "Use grid-auto-flow: dense (fills gaps)." }
      }
    },
    "artifact-organizer/CountdownTimer": {
      "description": "Live-updating countdown to a target datetime. Renders 4 cells (days/hours/minutes/seconds) with pulsing status label. Switches to 'LIVE' state at target.",
      "children": "forbidden",
      "props": {
        "target":    { "type": "string", "required": true, "description": "ISO 8601 datetime string (with timezone). Example: '2026-03-08T03:00:00+11:00'." },
        "label":     { "type": "string", "description": "Status label above the timer (default: omitted)." },
        "liveLabel": { "type": "string", "description": "Label shown when target is reached (default: 'LIVE NOW')." }
      }
    },
    "artifact-organizer/SiteHeader": {
      "description": "Sticky site-mode header — brand wordmark + nav links + CTA pill. Use as first child of a chromeless Page.",
      "children": "forbidden",
      "props": {
        "brand":     { "type": "string", "required": true, "description": "Brand wordmark text." },
        "brandHref": { "type": "string", "description": "Optional href on the brand wordmark." },
        "links":     { "type": "array", "items": { "type": "object", "props": { "label": { "type": "string", "required": true }, "href": { "type": "string", "required": true } } } },
        "cta":       { "type": "object", "props": { "label": { "type": "string", "required": true }, "href": { "type": "string" } }, "description": "Optional right-side CTA pill with pulsing dot." }
      }
    },
    "artifact-organizer/HeroCarousel": {
      "description": "Full-viewport-height rotating image carousel. Slides crossfade automatically; counter '1/N' and Play Reel pill overlay at bottom. Pauses on hover.",
      "children": "forbidden",
      "props": {
        "slides":   { "type": "array", "required": true, "items": { "type": "object", "props": { "image": { "type": "string", "required": true }, "title": { "type": "string" }, "subtitle": { "type": "string" } } } },
        "interval": { "type": "number", "default": 5500, "description": "Milliseconds between slide transitions (min 2000)." },
        "playReel": { "type": "object", "props": { "label": { "type": "string", "required": true }, "url": { "type": "string" } } },
        "lead":     { "type": "string", "description": "Editorial subtitle text shown directly below the hero image." }
      }
    },
    "artifact-organizer/EditorialStatement": {
      "description": "Massive centered editorial text block — for brand statements like 'Three unique companies under one roof'. ~70vh tall.",
      "children": "forbidden",
      "props": {
        "text":    { "type": "string", "required": true },
        "eyebrow": { "type": "string", "description": "Small uppercase label above the text." },
        "cta":     { "type": "object", "props": { "label": { "type": "string", "required": true }, "href": { "type": "string" } } }
      }
    },
    "artifact-organizer/DivisionCard": {
      "description": "Vertical division card — image (4:5 portrait) + title + description + linked project list + CTA. Place 3 in a Section to recreate a Studios/Productions/Touring layout.",
      "children": "forbidden",
      "props": {
        "title":       { "type": "string", "required": true },
        "eyebrow":     { "type": "string", "description": "Small label above the title (e.g., 'Division 01')." },
        "description": { "type": "string" },
        "image":       { "type": "string" },
        "projects":    { "type": "array", "items": { "type": "object", "props": { "label": { "type": "string", "required": true }, "href": { "type": "string" } } }, "description": "Linked project preview list shown below description." },
        "cta":         { "type": "object", "props": { "label": { "type": "string", "required": true }, "href": { "type": "string" } } }
      }
    },
    "artifact-organizer/WorkTypeRow": {
      "description": "Horizontal alternating row — image one side, body the other. Stacks on mobile. Use multiple in sequence with alternating align values.",
      "children": "forbidden",
      "props": {
        "title":       { "type": "string", "required": true },
        "description": { "type": "string" },
        "image":       { "type": "string" },
        "meta":        { "type": "array", "items": { "type": "string" }, "description": "Small uppercase chips (categories/services)." },
        "align":       { "type": "string", "enum": ["left", "right"], "default": "left", "description": "Image side." },
        "cta":         { "type": "object", "props": { "label": { "type": "string", "required": true }, "href": { "type": "string" } } }
      }
    },
    "artifact-organizer/PressMentions": {
      "description": "Press/media credit row — eyebrow label + list of publication names with optional notes. Use between Divisions and Work sections.",
      "children": "forbidden",
      "props": {
        "eyebrow":  { "type": "string", "description": "Label above the list, e.g. 'As featured in'." },
        "mentions": { "type": "array", "required": true, "items": { "type": "object", "props": { "name": { "type": "string", "required": true }, "note": { "type": "string" } } } }
      }
    },
    "artifact-organizer/ArticleCard": {
      "description": "Newsletter article item — headline, summary, source, date, tag, and optional link. Stack inside a Section to build a newsletter digest.",
      "children": "forbidden",
      "props": {
        "headline": { "type": "string", "required": true, "description": "Article title." },
        "summary":  { "type": "string", "required": true, "description": "One or two sentence summary." },
